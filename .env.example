QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=media_items
GOOGLE_API_KEY=your_api_key_here
PLEXAPI_AUTH_SERVER_BASEURL=http://your-plex-host:32400
PLEXAPI_AUTH_SERVER_TOKEN=your_plex_token_here
PLEX_MOVIE_LIBRARY="All Movies"
DUCKDB_PATH=/absolute/path/to/plex-ingest/data/plex_ingest.duckdb
# Must be a persistent directory, not left unset — dynamic partitions (imdb_id) and
# the concurrency pool limits below live in this instance's storage, and need to
# survive across separate `dg launch`/sensor invocations, not just one dev session.
DAGSTER_HOME=/absolute/path/to/plex-ingest/.dagster_home
